#pragma once

/*
* Version information for the Scitix In-Memory Middleware (SiMM)
* 
* version.h will be generated by CMake
*
* Before new release, update MAJOR, MINOR, PATCH version numbers
* For MAJOR version, it includes new features or architecture changes, and maybe INCOMPATIBLE with previous version
* For MINOR version, it includes new features or massive bugfixs, and should be COMPATIBLE with previous version
* For PATCH version, it includes bugfixes or minor changes, and should be COMPATIBLE with previous version
*/
#define SIMM_VERSION_MAJOR 0
#define SIMM_VERSION_MINOR 1
#define SIMM_VERSION_PATCH 0

#define SIMM_GIT_COMMIT_SHORT_HASH  "@SIMM_GIT_COMMIT_SHORT_HASH_CMAKE@"
#define SIMM_GIT_COMMIT_FULL_HASH   "@SIMM_GIT_COMMIT_FULL_HASH_CMAKE@"
#define SIMM_BUILD_TIME_STAMP       "@SIMM_BUILD_TIMESTAMP_CMAKE@"
#define SIMM_BUILD_TYPE             "@SIMM_BUILD_TYPE_CMAKE@"